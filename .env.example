# PROMETHEUS Environment Variables
# Copy to .env (NEVER commit .env)

# === Google Cloud ===
GOOGLE_CLOUD_PROJECT=prometheus-prod
GOOGLE_CLOUD_REGION=us-central1
# Use Workload Identity Federation in prod. Local dev only:
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# === Gemini / Vertex AI ===
GEMINI_API_KEY=your-gemini-key
VERTEX_AI_LOCATION=us-central1
VERTEX_AGENT_ENGINE_ID=
VERTEX_SAFETY_ENABLED=true

# === Firestore / Firebase Admin ===
FIRESTORE_DATABASE=(default)
FIREBASE_PROJECT_ID=prometheus-prod

# === Firebase Web SDK (frontend, prefixed VITE_) ===
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=prometheus-prod.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=prometheus-prod
VITE_FIREBASE_STORAGE_BUCKET=prometheus-prod.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_BACKEND_URL=http://localhost:8080
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com

# === Backend ===
BACKEND_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:5173,https://prometheus.app
LOG_LEVEL=INFO
ENV=dev
SECRET_KEY=change-me-32-bytes-random

# === Cloud Tasks ===
CLOUD_TASKS_QUEUE=prometheus-pipeline
CLOUD_TASKS_LOCATION=us-central1
CLOUD_TASKS_WORKER_URL=https://worker-xxxxx-uc.a.run.app/internal/run
CLOUD_TASKS_INVOKER_SA=tasks-invoker@prometheus-prod.iam.gserviceaccount.com

# === Stripe ===
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
STRIPE_PRICE_FOUNDER=price_
STRIPE_PRICE_FOUNDER_PRO=price_
STRIPE_PRICE_TEAM=price_

# === External data APIs ===
DEEPGRAM_API_KEY=
USPTO_API_KEY=
DOMAINR_API_KEY=
CRUNCHBASE_API_KEY=
STATISTA_API_KEY=
SIMILARWEB_API_KEY=
IMAGEN_LOCATION=us-central1
RECRAFT_API_KEY=

# === Deploy / hosting ===
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=

# === Notifications ===
RESEND_API_KEY=
SENDGRID_API_KEY=
FCM_SERVER_KEY=

# === Cost guardrails ===
MAX_TOKENS_PER_SESSION=120000
MAX_COST_USD_PER_SESSION=2.50
DAILY_FREE_GENERATIONS=1
HOURLY_RATE_LIMIT_PER_UID=3
DAILY_RATE_LIMIT_PER_UID=20
INPUT_LENGTH_CAP_CHARS=2000
